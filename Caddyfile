# SITE_ADDRESS comes from .env (via the caddy service's environment).
#   - a domain (e.g. game.example.com) -> Caddy auto-provisions HTTPS certs
#   - the default ":80"                 -> plain HTTP (fine for an IP-only test)
# HTTPS is strongly recommended: team passwords are sent at login.
{$SITE_ADDRESS::80} {
	# reverse_proxy transparently handles the WebSocket upgrade too.
	reverse_proxy app:8000
}
