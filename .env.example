# Copy to .env and adjust. For local dev the defaults work as-is.

# Postgres (used by both the db container and the app)
POSTGRES_USER=game
POSTGRES_PASSWORD=game
POSTGRES_DB=andrejsala

# App
# NOTE: host "db" is the compose service name; asyncpg driver.
DATABASE_URL=postgresql+asyncpg://game:game@db:5432/andrejsala
# CHANGE THIS for anything reachable from the internet:
SECRET_KEY=dev-secret-change-me

# Game tuning
TICK_SECONDS=5
BASE_TAX=0.35
START_IP=400
DAILY_IP=100

# Seed credentials (first boot only)
ADMIN_USERNAME=admin
ADMIN_PASSWORD=admin
