# Copy to .env and adjust. For LOCAL dev the defaults work as-is.
# For PRODUCTION (Hetzner) change every value marked "CHANGE" below.

# --- Postgres (used by both the db container and the app) ---
POSTGRES_USER=game
POSTGRES_PASSWORD=game            # CHANGE: strong password in prod
POSTGRES_DB=andrejsala

# --- App ---
# Keep user/password/db here in sync with the POSTGRES_* values above.
DATABASE_URL=postgresql+asyncpg://game:game@db:5432/andrejsala

# CHANGE: signs the login session cookie — must be long & random in prod.
#   generate with:  openssl rand -hex 32
SECRET_KEY=dev-secret-change-me

# --- Deployment / HTTPS ---
# Local/IP-only: leave as ":80" (plain HTTP).
# Production with a domain: set to that domain (e.g. game.example.com) and Caddy
# will auto-provision + renew HTTPS certificates. DNS must point at the VM first.
SITE_ADDRESS=:80

# --- Game tuning ---
TICK_SECONDS=5
BASE_TAX=0.35
START_IP=400
DAILY_IP=100

# --- Seed credentials (applied only when the admin doesn't exist yet, i.e. a
#     fresh database). CHANGE the password in prod. ---
ADMIN_USERNAME=admin
ADMIN_PASSWORD=admin              # CHANGE in prod
